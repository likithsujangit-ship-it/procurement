{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": {
      "type": "string",
      "const": "purchase_order"
    },
    "document_type": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Purchase_Order", "Delivery_Schedule", "Price_List", "Signed_Approval"]
      },
      "minItems": 1
    },
    "buyer": {
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "contact_name": { "type": "string" },
        "contact_title": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "gstin": { "type": "string", "pattern": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[0-9A-Z]{1}Z[0-9A-Z]{1}$" }
      },
      "required": ["company_name", "contact_name", "email", "phone", "address", "gstin"],
      "additionalProperties": false
    },
    "supplier": {
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "contact_name": { "type": "string" },
        "contact_title": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" }
      },
      "required": ["company_name", "contact_name", "email", "address"],
      "additionalProperties": false
    },
    "po_number": { "type": "string" },
    "po_date": { "type": "string", "format": "date" },
    "reference_rfq_number": { "type": "string" },
    "approval_status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "part_number": { "type": "string" },
          "description": { "type": "string" },
          "quantity": { "type": ["integer", "number", "null"] },
          "unit": { "type": "string" },
          "material_spec": { "type": "string" }
        },
        "required": ["part_number", "description", "quantity", "unit", "material_spec"],
        "additionalProperties": false
      }
    },
    "commercial_terms": {
      "type": "object",
      "properties": {
        "payment_terms": { "type": "string" },
        "incoterms": { "type": "string" },
        "currency": { "type": "string" },
        "total_order_value": { "type": ["number", "null"] },
        "delivery_schedule": { "type": ["string", "array"] },
        "gst_rate": { "type": "string" },
        "tds_rate": { "type": "string" },
        "security_deposit": { "type": "string" },
        "performance_bank_guarantee": { "type": "string", "description": "Performance bank guarantee rate or requirement, e.g., 10% value of purchase order" },
        "liquidated_damages": { "type": "string" },
        "delivery_requirement": { "type": "string", "description": "Delivery period or requirement, e.g., within 30 days from receipt of PO" },
        "landed_price_methodology": { "type": "string" }
      },
      "required": ["payment_terms", "incoterms", "currency", "total_order_value", "delivery_schedule"],
      "additionalProperties": false
    },
    "shipping_details": {
      "type": "object"
    },
    "approval": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "approved_by": { "type": "string" },
        "approval_date": { "type": "string" }
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": { "type": "string", "enum": ["Purchase_Order", "Delivery_Schedule", "Price_List", "Signed_Approval"] },
          "contains": { 
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        },
        "required": ["filename", "type", "contains"],
        "additionalProperties": false
      }
    },
    "missing_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conflicts": {
      "type": "array"
    },
    "llm_confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": [
    "intent", "document_type", "buyer", "supplier", "po_number", "po_date", "items", 
    "commercial_terms", "attachments", "missing_fields", "conflicts", "llm_confidence_score"
  ],
  "additionalProperties": false
}
