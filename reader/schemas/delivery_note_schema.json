{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": { "type": "string", "const": "delivery_note" },
    "document_type": {
      "type": "array",
      "items": { "type": "string", "enum": ["Delivery_Note", "Packing_List", "Bill_of_Lading"] },
      "minItems": 1
    },
    "buyer": { "type": "object", "properties": { "company_name": { "type": "string" }, "delivery_address": { "type": "string" } }, "required": ["company_name"] },
    "supplier": { "type": "object", "properties": { "company_name": { "type": "string" } }, "required": ["company_name"] },
    "delivery_note_number": { "type": "string" },
    "dispatch_date": { "type": "string", "format": "date" },
    "delivery_date": { "type": "string", "format": "date" },
    "reference_po_number": { "type": "string" },
    "tracking_number": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "part_number": { "type": "string" },
          "description": { "type": "string" },
          "items_shipped": { "type": ["integer", "number", "null"] }
        },
        "required": ["description", "items_shipped"]
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": { "type": "string", "enum": ["Delivery_Note", "Packing_List", "Bill_of_Lading"] },
          "contains": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["filename", "type"]
      }
    },
    "missing_fields": { "type": "array", "items": { "type": "string" } },
    "conflicts": { "type": "array" },
    "llm_confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "required": ["intent", "document_type", "buyer", "supplier", "delivery_note_number", "items", "attachments"],
  "additionalProperties": false
}
