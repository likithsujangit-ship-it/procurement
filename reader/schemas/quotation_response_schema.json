{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": { "type": "string", "const": "quotation_response" },
    "document_type": {
      "type": "array",
      "items": { "type": "string", "enum": ["Quotation", "Price_Breakdown", "Technical_Proposal"] },
      "minItems": 1
    },
    "buyer": { "type": "object", "properties": { "company_name": { "type": "string" }, "contact_name": { "type": "string" } }, "required": ["company_name"] },
    "supplier": { "type": "object", "properties": { "company_name": { "type": "string" }, "contact_name": { "type": "string" }, "email": { "type": "string" } }, "required": ["company_name"] },
    "quotation_number": { "type": "string" },
    "quotation_date": { "type": "string", "format": "date" },
    "valid_until": { "type": "string", "format": "date" },
    "reference_rfq_number": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "part_number":  { "type": ["string", "null"] },
          "description":  { "type": ["string", "null"] },
          "quantity":     { "type": ["integer", "number", "null"] },
          "unit_price":   { "type": ["number", "null"] },
          "total_price":  { "type": ["number", "null"] },
          "vendor_quotes": {
            "type": ["array", "null"],
            "description": "All vendor bids for this item from a price comparison/evaluation sheet.",
            "items": {
              "type": "object",
              "properties": {
                "vendor_name":  { "type": "string" },
                "quoted_price": { "type": ["number", "null"] },
                "landed_price": { "type": ["number", "null"] },
                "rank":         { "type": ["string", "null"], "description": "L1 = lowest, L2, L3... as shown in source" },
                "is_selected":  { "type": ["boolean", "null"], "description": "true only for winning/lowest vendor" }
              },
              "required": ["vendor_name", "quoted_price", "rank", "is_selected"]
            }
          }
        },
        "required": ["description", "quantity", "unit_price", "total_price"]
      }
    },
    "commercial_terms": { "type": "object" },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": { "type": "string", "enum": ["Quotation", "Price_Breakdown", "Technical_Proposal"] },
          "contains": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["filename", "type"]
      }
    },
    "missing_fields": { "type": "array", "items": { "type": "string" } },
    "conflicts": { "type": "array" },
    "llm_confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "required": ["intent", "document_type", "buyer", "supplier", "quotation_number", "quotation_date", "items", "attachments"]
}
