{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": { "type": "string", "const": "invoice" },
    "document_type": {
      "type": "array",
      "items": { "type": "string", "enum": ["Invoice", "Tax_Document", "Receipt"] },
      "minItems": 1
    },
    "buyer": { "type": "object", "properties": { "company_name": { "type": "string" } }, "required": ["company_name"] },
    "supplier": { "type": "object", "properties": { "company_name": { "type": "string" }, "bank_details": { "type": "string" } }, "required": ["company_name"] },
    "invoice_number": { "type": "string" },
    "invoice_date": { "type": "string", "format": "date" },
    "due_date": { "type": "string", "format": "date" },
    "reference_po_number": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "quantity": { "type": "integer" },
          "unit_price": { "type": "number" },
          "tax_amount": { "type": "number" },
          "total": { "type": "number" }
        },
        "required": ["description", "quantity", "unit_price", "total"]
      }
    },
    "commercial_terms": {
      "type": "object",
      "properties": {
        "payment_terms": { "type": "string" },
        "amount_due": { "type": "number" },
        "currency": { "type": "string" }
      },
      "required": ["amount_due", "currency"]
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": { "type": "string", "enum": ["Invoice", "Tax_Document", "Receipt"] },
          "contains": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["filename", "type"]
      }
    },
    "missing_fields": { "type": "array", "items": { "type": "string" } },
    "conflicts": { "type": "array" },
    "llm_confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "required": ["intent", "document_type", "buyer", "supplier", "invoice_number", "invoice_date", "items", "commercial_terms", "attachments"],
  "additionalProperties": false
}
