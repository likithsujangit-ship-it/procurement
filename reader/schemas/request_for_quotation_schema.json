{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": {
      "type": "string",
      "const": "request_for_quotation"
    },
    "document_type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "buyer": {
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "address": { "type": "string" },
        "gstin": { "type": "string" },
        "contact_name": { "type": "string" },
        "contact_title": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["company_name", "contact_name", "email"]
    },
    "supplier": {
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "address": { "type": "string" },
        "contact_name": { "type": "string" },
        "contact_title": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["company_name", "contact_name", "email"]
    },
    "rfq_number": { "type": "string" },
    "rfq_issue_date": { "type": "string" },
    "quotation_due_date": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "line": { "type": "integer" },
          "part_number": { "type": "string" },
          "description": { "type": "string" },
          "quantity": { "type": "integer" },
          "unit": { "type": "string" },
          "material_grade": { "type": "string" }
        },
        "required": ["part_number", "description", "quantity", "unit"]
      }
    },
    "commercial_terms": {
      "type": "object",
      "properties": {
        "payment_terms": { "type": "string" },
        "incoterms": { "type": "string" },
        "currency": { "type": "string" },
        "quotation_validity": { "type": "string" },
        "warranty": { "type": "string" }
      }
    },
    "delivery_requirements": {
      "type": "object",
      "properties": {
        "delivery_location": { "type": "string" },
        "required_delivery_date": { "type": "string" },
        "delivery_split": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "split": { "type": "string" },
              "percentage": { "type": "number" },
              "date": { "type": "string" }
            }
          }
        },
        "partial_shipments_allowed": { "type": "boolean" }
      }
    },
    "shipping_details": {
      "type": "object"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": { "type": "string" },
          "extracted": { "type": "boolean" }
        },
        "required": ["filename"]
      }
    },
    "missing_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conflicts": {
      "type": "array"
    },
    "confidence_score": {
      "type": "number"
    }
  },
  "required": [
    "intent", "document_type", "buyer", "supplier", "rfq_number", "rfq_issue_date", "quotation_due_date", "items", 
    "commercial_terms", "delivery_requirements", "shipping_details", 
    "attachments", "missing_fields", "conflicts", "confidence_score"
  ]
}
