{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": {
      "anyOf": [
        {
          "type": "string",
          "enum": ["request_for_quotation"]
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["request_for_quotation"]
          }
        }
      ]
    },
    "document_type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "buyer": {
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "address": { "type": "string" },
        "gstin": { "type": "string" },
        "contact_name": { "type": "string" },
        "contact_title": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["company_name", "contact_name", "email"]
    },
    "supplier": {
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "address": { "type": "string" },
        "contact_name": { "type": "string" },
        "contact_title": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["company_name", "contact_name", "email"]
    },
    "rfq_number": { "type": "string" },
    "rfq_issue_date": { "type": "string" },
    "quotation_due_date": { "type": "string" },
    "date_extended_from": { "type": ["string", "null"] },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "line":           { "type": ["integer", "null"] },
          "part_number":    { "type": ["string", "null"] },
          "description":    { "type": ["string", "null"] },
          "quantity":       { "type": ["integer", "number", "null"] },
          "unit":           { "type": ["string", "null"] },
          "material_grade": { "type": ["string", "null"] },
          "unit_price":     { "type": ["number", "null"] },
          "currency":       { "type": ["string", "null"] },
          "line_total":     { "type": ["number", "null"] },
          "vendor_quotes": {
            "type": "array",
            "description": "All vendor bids for this item from a price comparison/evaluation sheet.",
            "items": {
              "type": "object",
              "properties": {
                "vendor_name":  { "type": ["string", "null"] },
                "quoted_price": { "type": ["number", "null"] },
                "landed_price": { "type": ["number", "null"] },
                "rank":         { "type": ["string", "null"], "description": "L1 = lowest, L2, L3... as shown in source" },
                "is_selected":  { "type": ["boolean", "null"], "description": "true only for winning/lowest vendor" }
              },
              "required": ["vendor_name", "quoted_price", "rank", "is_selected"]
            }
          }
        },
        "required": ["part_number", "description", "quantity", "unit"]
      }
    },
    "commercial_terms": {
      "type": "object",
      "properties": {
        "payment_terms": { "type": "string" },
        "incoterms": { "type": "string" },
        "currency": { "type": "string" },
        "quotation_validity": { "type": "string" },
        "warranty": { "type": "string" }
      }
    },
    "delivery_requirements": {
      "type": "object",
      "properties": {
        "delivery_location": { "type": "string" },
        "required_delivery_date": { "type": "string" },
        "delivery_split": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "properties": {
              "split": { "type": "string" },
              "percentage": { "type": "number" },
              "date": { "type": "string" }
            }
          }
        },
        "partial_shipments_allowed": { "type": ["boolean", "null"] }
      }
    },
    "shipping_details": {
      "type": "object"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": { "type": "string" },
          "extracted": { "type": "boolean" }
        },
        "required": ["filename"]
      }
    },
    "missing_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conflicts": {
      "type": "array"
    },
    "llm_confidence_score": {
      "type": "number"
    },
    "procurement_status": {
      "type": "object"
    },
    "validation": {
      "type": "object"
    },
    "missing_procurement_information": {
      "type": "array"
    },
    "recommendation": {
      "type": "string"
    }
  },
  "required": [
    "intent", "document_type", "buyer", "supplier", "rfq_number", "rfq_issue_date", "quotation_due_date", "items", 
    "commercial_terms", "delivery_requirements", "shipping_details", 
    "attachments", "missing_fields", "conflicts", "llm_confidence_score",
    "procurement_status", "validation", "missing_procurement_information", "recommendation"
  ]
}
