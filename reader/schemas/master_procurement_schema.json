{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "request_for_quotation",
        "purchase_order_issuance",
        "shipment_dispatch_notification",
        "invoice_only",
        "other"
      ]
    },
    "document_type": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "buyer": {
      "type": "object"
    },
    "supplier": {
      "type": "object"
    },
    "rfq_number": {
      "type": [
        "string",
        "null"
      ]
    },
    "po_number": {
      "type": [
        "string",
        "null"
      ]
    },
    "invoice_number": {
      "type": [
        "string",
        "null"
      ]
    },
    "shipment_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "commercial_terms": {
      "type": "object",
      "properties": {
        "payment_terms": {
          "type": "string"
        },
        "incoterms": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "warranty": {
          "type": "string"
        },
        "delivery_requirement": {
          "type": "string"
        },
        "gst_rate": {
          "type": "string"
        },
        "tds_rate": {
          "type": "string"
        },
        "security_deposit": {
          "type": "string"
        },
        "performance_bank_guarantee": {
          "type": "string"
        },
        "liquidated_damages": {
          "type": "string"
        },
        "landed_price_methodology": {
          "type": "string"
        }
      }
    },
    "delivery_requirements": {
      "type": "object",
      "properties": {
        "required_delivery_date": {
          "type": "string"
        },
        "delivery_location": {
          "type": "string"
        }
      }
    },
    "shipping_details": {
      "type": "object"
    },
    "approval": {
      "type": "object"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflicts": {
      "type": "array"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "procurement_status": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "COMPLETE",
            "INCOMPLETE"
          ]
        },
        "completeness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": [
        "status",
        "completeness_score"
      ]
    },
    "validation": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASSED",
            "FAILED"
          ]
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "reason"
      ]
    },
    "missing_procurement_information": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendation": {
      "type": "string"
    }
  },
  "required": [
    "intent",
    "document_type",
    "buyer",
    "supplier",
    "rfq_number",
    "po_number",
    "invoice_number",
    "shipment_id",
    "items",
    "commercial_terms",
    "delivery_requirements",
    "shipping_details",
    "approval",
    "attachments",
    "missing_fields",
    "conflicts",
    "confidence_score",
    "procurement_status",
    "validation",
    "missing_procurement_information",
    "recommendation"
  ]
}