{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "request_for_quotation",
        "purchase_order_issuance",
        "shipment_dispatch_notification",
        "invoice_only",
        "other"
      ]
    },
    "document_type": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "buyer": {
      "type": "object"
    },
    "supplier": {
      "type": "object"
    },
    "rfq_number": {
      "type": [
        "string",
        "null"
      ]
    },
    "po_number": {
      "type": [
        "string",
        "null"
      ]
    },
    "invoice_number": {
      "type": [
        "string",
        "null"
      ]
    },
    "invoice_date": {
      "type": [
        "string",
        "null"
      ],
      "description": "Invoice issuance date"
    },
    "rfq_issue_date": {
      "type": [
        "string",
        "null"
      ],
      "description": "Request for quotation issue date"
    },
    "quotation_due_date": {
      "type": [
        "string",
        "null"
      ],
      "description": "Quotation due date"
    },
    "date_extended_from": {
      "type": [
        "string",
        "null"
      ],
      "description": "Original quotation due date before extension"
    },
    "po_date": {
      "type": [
        "string",
        "null"
      ],
      "description": "Purchase order date"
    },
    "delivery_note_number": {
      "type": [
        "string",
        "null"
      ],
      "description": "Delivery challan, manifest, or packing slip number"
    },
    "dispatch_date": {
      "type": [
        "string",
        "null"
      ],
      "description": "Dispatch or shipment date from delivery note"
    },
    "quotation_number": {
      "type": [
        "string",
        "null"
      ],
      "description": "Supplier quotation reference number"
    },
    "quotation_date": {
      "type": [
        "string",
        "null"
      ],
      "description": "Supplier quotation date"
    },
    "effective_date": {
      "type": [
        "string",
        "null"
      ],
      "description": "Effective date of vendor price list catalog"
    },
    "valid_until": {
      "type": [
        "string",
        "null"
      ],
      "description": "Expiry date of vendor price list catalog"
    },
    "shipment_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "commercial_terms": {
      "type": "object",
      "properties": {
        "payment_terms": {
          "type": "string"
        },
        "incoterms": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "warranty": {
          "type": "string"
        },
        "delivery_requirement": {
          "type": "string",
          "description": "Delivery period or requirement, e.g., within 30 days from receipt of PO"
        },
        "gst_rate": {
          "type": "string"
        },
        "tds_rate": {
          "type": "string"
        },
        "security_deposit": {
          "type": "string"
        },
        "performance_bank_guarantee": {
          "type": "string",
          "description": "Performance bank guarantee rate or requirement, e.g., 10% value of purchase order"
        },
        "liquidated_damages": {
          "type": "string"
        },
        "landed_price_methodology": {
          "type": "string"
        }
      }
    },
    "delivery_requirements": {
      "type": "object",
      "properties": {
        "required_delivery_date": {
          "type": "string"
        },
        "delivery_location": {
          "type": "string"
        }
      }
    },
    "shipping_details": {
      "type": "object"
    },
    "approval": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "approved_by": { "type": "string" },
        "approval_date": { "type": "string" }
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflicts": {
      "type": "array"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "procurement_status": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "COMPLETE",
            "INCOMPLETE"
          ]
        },
        "completeness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": [
        "status",
        "completeness_score"
      ]
    },
    "validation": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASSED",
            "FAILED"
          ]
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "reason"
      ]
    },
    "missing_procurement_information": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendation": {
      "type": "string"
    }
  },
  "required": [
    "intent",
    "document_type",
    "buyer",
    "supplier",
    "rfq_number",
    "po_number",
    "invoice_number",
    "shipment_id",
    "items",
    "commercial_terms",
    "delivery_requirements",
    "shipping_details",
    "approval",
    "attachments",
    "missing_fields",
    "conflicts",
    "confidence_score",
    "procurement_status",
    "validation",
    "missing_procurement_information",
    "recommendation"
  ]
}