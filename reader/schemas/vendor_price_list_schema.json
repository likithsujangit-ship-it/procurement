{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": {
      "anyOf": [
        {
          "type": "string",
          "enum": ["vendor_price_list"]
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["vendor_price_list"]
          }
        }
      ]
    },
    "document_type": {
      "type": "array",
      "items": { "type": "string", "enum": ["Price_List", "Catalog"] },
      "minItems": 1
    },
    "supplier": { "type": "object", "properties": { "company_name": { "type": "string" }, "contact_name": { "type": "string" } }, "required": ["company_name"] },
    "effective_date": { "type": "string", "format": "date" },
    "valid_until": { "type": "string", "format": "date" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "part_number": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] },
          "unit_price": { "type": ["number", "null"] },
          "currency": { "type": ["string", "null"] }
        },
        "required": ["description", "unit_price", "currency"]
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": { "type": "string" },
          "contains": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["filename", "type"]
      }
    },
    "missing_fields": { "type": "array", "items": { "type": "string" } },
    "conflicts": { "type": "array" },
    "llm_confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "required": ["intent", "document_type", "supplier", "items", "attachments"],
  "additionalProperties": false
}
